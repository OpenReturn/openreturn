{
  "name": "@openreturn/api",
  "version": "0.1.0",
  "private": true,
  "description": "OpenReturn REST API reference server",
  "license": "Apache-2.0",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src test --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema ../../prisma/schema.prisma",
    "prisma:dev": "prisma migrate dev --schema ../../prisma/schema.prisma"
  },
  "dependencies": {
    "@openreturn/adapters": "workspace:*",
    "@openreturn/core": "workspace:*",
    "@openreturn/return-methods": "workspace:*",
    "@openreturn/types": "workspace:*",
    "@prisma/client": "^6.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.10.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^6.6.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "vitest": "^3.1.1"
  }
}
